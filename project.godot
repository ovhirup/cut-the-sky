; Engine configuration file.
; Cut the Sky — kite-fighting score attack for macOS.
; Engine pinned: Godot 4.7.x stable. Do not upgrade mid-project.

config_version=5

[application]

config/name="Cut the Sky"
config/description="Guide your kite. Tighten the line. Cut a path through the sky."
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")

[display]

window/size/viewport_width=1440
window/size/viewport_height=900
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[input_devices]

pointing/emulate_touch_from_mouse=false

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
